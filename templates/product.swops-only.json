{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "title": {
          "type": "title"
        },
        "untertitel": {
          "type": "text",
          "settings": {
            "text": "Wechselbare Design-Einlage – passt in jede transparente Hülle",
            "text_style": "subtitle"
          }
        },
        "price": {
          "type": "price"
        },
        "rabatt_kontext": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% render 'swopcase-bundle-kontext' %}"
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "dropdown"
          }
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false
          }
        },
        "trust_icons": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% render 'swopcase-trust-icons' %}"
          }
        },
        "description": {
          "type": "description"
        },
        "tab_material": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Material & Passform",
            "icon": "ruler",
            "content": "<p>Dünne, passgenaue Design-Einlage für dein iPhone-Modell. Einfach zwischen Hülle und Handy einlegen – ohne Kleben, beliebig oft wechselbar.</p>",
            "page": ""
          }
        },
        "tab_versand": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Versand & Lieferung",
            "icon": "truck",
            "content": "<p>Schneller Versand mit Sendungsverfolgung. Die genauen Versandkosten siehst du im Checkout.</p>",
            "page": ""
          }
        },
        "tab_rueckgabe": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "30 Tage Rückgabe",
            "icon": "return",
            "content": "<p>30 Tage Rückgaberecht – ohne Wenn und Aber. Schreib uns einfach und du bekommst alles, was du für die Rücksendung brauchst.</p>",
            "page": ""
          }
        }
      },
      "block_order": [
        "title",
        "untertitel",
        "price",
        "rabatt_kontext",
        "variant_picker",
        "buy_buttons",
        "trust_icons",
        "description",
        "tab_material",
        "tab_versand",
        "tab_rueckgabe"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "stacked",
        "media_size": "medium",
        "constrain_to_viewport": true,
        "mobile_thumbnails": "hide",
        "hide_variants": true,
        "enable_video_looping": true,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "erklaerer": {
      "type": "swopcase-pdp-erklaerer",
      "blocks": {
        "schritt_1": {
          "type": "step",
          "settings": {
            "icon": "case",
            "label": "Hülle ab"
          }
        },
        "schritt_2": {
          "type": "step",
          "settings": {
            "icon": "insert",
            "label": "Swop rein"
          }
        },
        "schritt_3": {
          "type": "step",
          "settings": {
            "icon": "check",
            "label": "Look fertig"
          }
        }
      },
      "block_order": [
        "schritt_1",
        "schritt_2",
        "schritt_3"
      ],
      "settings": {
        "heading": "So funktioniert dein Swop",
        "note": "In Sekunden gewechselt – beliebig oft.",
        "background_color": "#F1E9E9",
        "padding_top": 32,
        "padding_bottom": 32
      }
    },
    "crosssell": {
      "type": "swopcase-crosssell",
      "settings": {
        "eyebrow": "Mehr Looks",
        "heading": "Kombiniere deine Lieblings-Designs",
        "collection": "all-swops",
        "products_to_show": 8,
        "show_view_all": true,
        "view_all_label": "Alle Designs ansehen",
        "background_color": "#F1E9E9",
        "padding_top": 56,
        "padding_bottom": 56
      }
    },
    "case_hinweis": {
      "type": "swopcase-produkt-erklaererband",
      "blocks": {
        "teil_case": {
          "type": "teil",
          "settings": {
            "placeholder_kind": "case",
            "badge": "Das Original",
            "title": "Die SwopCase",
            "text": "Transparente, sturzsichere Schutzhülle mit erhöhten Kanten. Funktioniert auch komplett ohne Swop.",
            "price_label": "14,99 €",
            "link_label": "Zur SwopCase",
            "link": "shopify://products/swopcase"
          }
        }
      },
      "block_order": [
        "teil_case"
      ],
      "settings": {
        "eyebrow": "Die Basis",
        "heading": "Noch keine SwopCase?",
        "intro": "Swops passen in jede transparente Hülle – und sitzen perfekt in unserer SwopCase.",
        "background_color": "#F1E9E9",
        "padding_top": 56,
        "padding_bottom": 56
      }
    },
    "trust": {
      "type": "swopcase-trust-band",
      "blocks": {
        "signal_versand": {
          "type": "signal",
          "settings": {
            "icon": "shipping",
            "label": "Schnelle Lieferung",
            "sub": "Versand aus Deutschland"
          }
        },
        "signal_rueckgabe": {
          "type": "signal",
          "settings": {
            "icon": "returns",
            "label": "30 Tage Rückgabe",
            "sub": "Ohne Wenn und Aber"
          }
        },
        "signal_zahlung": {
          "type": "signal",
          "settings": {
            "icon": "secure",
            "label": "Sichere Zahlung",
            "sub": "PayPal, Klarna, Apple Pay"
          }
        },
        "signal_passform": {
          "type": "signal",
          "settings": {
            "icon": "phone",
            "label": "Passt aufs iPhone",
            "sub": "iPhone 7 – 16 Pro Max"
          }
        }
      },
      "block_order": [
        "signal_versand",
        "signal_rueckgabe",
        "signal_zahlung",
        "signal_passform"
      ],
      "settings": {
        "background_color": "#FFFFFF",
        "padding_top": 32,
        "padding_bottom": 32
      }
    },
    "reviews": {
      "type": "swopcase-reviews",
      "blocks": {
        "review_1": {
          "type": "review",
          "settings": {
            "name": "Emma",
            "rating": 5,
            "date": "vor 1 Woche",
            "verified": true,
            "text": "die designs sind sooo schön, hab direkt 3 bestellt. wechseln dauert echt nur paar sekunden"
          }
        },
        "review_2": {
          "type": "review",
          "settings": {
            "name": "Sarah L.",
            "rating": 5,
            "date": "vor 2 Wochen",
            "verified": true,
            "text": "Qualität ist super, die Farben sehen genauso aus wie im Shop. Nächste Bestellung ist schon geplant haha"
          }
        },
        "review_3": {
          "type": "review",
          "settings": {
            "name": "Mel",
            "rating": 4,
            "date": "vor 1 Monat",
            "verified": true,
            "text": "Süße Designs! eins war beim einlegen minimal verschoben, nach neu einsetzen wars perfekt."
          }
        },
        "review_4": {
          "type": "review",
          "settings": {
            "name": "Hannah K.",
            "rating": 5,
            "date": "vor 3 Tagen",
            "verified": true,
            "text": "Endlich kein langweiliges case mehr. für den preis kann man echt nichts falsch machen."
          }
        }
      },
      "block_order": [
        "review_1",
        "review_2",
        "review_3",
        "review_4"
      ],
      "settings": {
        "eyebrow": "Bewertungen",
        "heading": "Das sagen unsere Kund:innen",
        "show_summary": true,
        "avg_rating": "4,8",
        "rating_count": "312",
        "background_color": "#F1E9E9",
        "padding_top": 56,
        "padding_bottom": 56
      }
    },
    "sticky": {
      "type": "swopcase-sticky-atc",
      "settings": {
        "enable": true,
        "button_label": "In den Warenkorb",
        "show_price": true,
        "show_on_desktop": false,
        "scroll_threshold": 600
      }
    }
  },
  "order": [
    "main",
    "erklaerer",
    "crosssell",
    "case_hinweis",
    "trust",
    "reviews",
    "sticky"
  ]
}
