{{ 'swopcase-theme.css' | asset_url | stylesheet_tag }}
{%- style -%}
  #swopcase-crosssell-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #swopcase-crosssell-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
<section id="swopcase-crosssell-{{ section.id }}" class="swop-section swopcase-crosssell"{% if section.settings.background_color != blank %} style="background-color: {{ section.settings.background_color }};"{% endif %}>
  <div class="swop-container">
    <div class="swopcase-crosssell__head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="swop-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="swop-title">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    {%- assign coll = section.settings.collection -%}
    {%- if coll != blank and coll.products_count > 0 -%}
      {%- comment -%}
        Auf Produktseiten wird das aktuell betrachtete Produkt übersprungen.
        Gezählt wird erst nach dem Filter, damit trotzdem die gewünschte
        Anzahl Karten erscheint.
      {%- endcomment -%}
      {%- assign max_items = section.settings.products_to_show -%}
      {%- assign shown = 0 -%}
      {%- capture crosssell_cards -%}
        {%- for cs_product in coll.products -%}
          {%- if product != blank and cs_product.id == product.id -%}
            {%- continue -%}
          {%- endif -%}
          {%- assign shown = shown | plus: 1 -%}
          <li class="swopcase-crosssell__item">
            <a class="swopcase-crosssell__card" href="{{ cs_product.url }}">
              <div class="swopcase-crosssell__media">
                {%- if cs_product.featured_image != blank -%}
                  <img class="swop-media" src="{{ cs_product.featured_image | image_url: width: 600 }}" alt="{{ cs_product.featured_image.alt | escape }}" width="600" height="600" loading="lazy">
                {%- else -%}
                  <img class="swop-media" src="{{ 'placeholder-swop.svg' | asset_url }}" alt="" width="600" height="600" loading="lazy">
                {%- endif -%}
              </div>
              <div class="swopcase-crosssell__info">
                <span class="swopcase-crosssell__name">{{ cs_product.title }}</span>
                <span class="swopcase-crosssell__price">
                  {%- if cs_product.price_varies -%}
                    ab {{ cs_product.price_min | money }}
                  {%- else -%}
                    {{ cs_product.price | money }}
                  {%- endif -%}
                </span>
              </div>
            </a>
          </li>
          {%- if shown >= max_items -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}

      {%- if shown > 0 -%}
        <ul class="swopcase-crosssell__grid" role="list">
          {{ crosssell_cards }}
        </ul>

        {%- if section.settings.show_view_all and coll.url != blank -%}
          <div class="swopcase-crosssell__actions">
            <a class="swop-btn swop-btn--secondary" href="{{ coll.url }}">{{ section.settings.view_all_label }}</a>
          </div>
        {%- endif -%}
      {%- endif -%}
    {%- else -%}
      <ul class="swopcase-crosssell__grid" role="list">
        {%- for i in (1..4) -%}
          <li class="swopcase-crosssell__item">
            <div class="swopcase-crosssell__card swopcase-crosssell__card--placeholder">
              <div class="swopcase-crosssell__media">
                <img class="swop-media" src="{{ 'placeholder-swop.svg' | asset_url }}" alt="" width="600" height="600" loading="lazy">
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>
      <p class="swopcase-crosssell__note">Wähle im Theme-Editor eine Kollektion.</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .swopcase-crosssell__head {
    margin-bottom: calc(var(--swop-space) * 1.2);
  }
  .swopcase-crosssell .swop-eyebrow {
    margin-bottom: 8px;
  }
  .swopcase-crosssell .swop-title {
    margin: 0;
  }

  .swopcase-crosssell__grid {
    list-style: none;
    margin: 0;
    padding: 0 0 8px 0;
    display: flex;
    gap: var(--swop-gutter);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .swopcase-crosssell__grid::-webkit-scrollbar {
    display: none;
  }
  .swopcase-crosssell__item {
    flex: 0 0 45vw;
    max-width: 45vw;
    scroll-snap-align: start;
  }

  .swopcase-crosssell__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--swop-ink);
    background-color: var(--swop-surface);
    border: 1px solid var(--swop-line);
    border-radius: var(--swop-radius);
    overflow: hidden;
    height: 100%;
    box-shadow: var(--swop-shadow-sm);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .swopcase-crosssell__card:hover,
  .swopcase-crosssell__card:focus-visible {
    box-shadow: var(--swop-shadow);
    transform: translateY(-2px);
  }
  .swopcase-crosssell__card--placeholder {
    cursor: default;
  }

  .swopcase-crosssell__media {
    position: relative;
    aspect-ratio: 1 / 1;
    background-color: var(--swop-surface-2);
  }
  .swopcase-crosssell__media .swop-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .swopcase-crosssell__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px;
  }
  .swopcase-crosssell__name {
    font-size: 0.875rem;
    line-height: 1.3;
    color: var(--swop-ink-soft);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .swopcase-crosssell__price {
    font-weight: 700;
    color: var(--swop-ink);
    font-size: 0.95rem;
  }

  .swopcase-crosssell__note {
    margin: 14px 0 0 0;
    font-size: 0.875rem;
    color: var(--swop-ink-soft);
  }

  .swopcase-crosssell__actions {
    margin-top: calc(var(--swop-space) * 1.1);
    display: flex;
    justify-content: center;
  }

  @media screen and (min-width: 750px) {
    .swopcase-crosssell__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      overflow: visible;
      padding-bottom: 0;
    }
    .swopcase-crosssell__item {
      flex: none;
      max-width: none;
    }
    .swopcase-crosssell__name {
      font-size: 0.9375rem;
    }
    .swopcase-crosssell__price {
      font-size: 1rem;
    }
  }

  @media screen and (min-width: 990px) {
    .swopcase-crosssell__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SwopCase: Cross-Sell",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (kleine Überschrift)",
      "info": "Optional. Kurzer Text über der Hauptüberschrift.",
      "default": "Passt dazu"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Überschrift",
      "default": "Vergiss deine Swops nicht"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion",
      "info": "Wähle die Kollektion, aus der die Produkte angezeigt werden."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Anzahl der Produkte",
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Button \"Alle ansehen\" zeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Button-Text",
      "default": "Alle Swops ansehen"
    },
    {
      "type": "header",
      "content": "Darstellung"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Hintergrundfarbe",
      "default": "#F1E9E9"
    },
    {
      "type": "header",
      "content": "Abstand"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "SwopCase: Cross-Sell"
    }
  ]
}
{% endschema %}
