{{ 'swopcase-theme.css' | asset_url | stylesheet_tag }}
{%- style -%}
  #swopcase-ugc-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #swopcase-ugc-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
<section id="swopcase-ugc-{{ section.id }}" class="swop-section swopcase-ugc"{% if section.settings.background_color != blank %} style="background-color: {{ section.settings.background_color }};"{% endif %}>
  <div class="swop-container">
    {%- if section.settings.eyebrow != blank -%}
      <p class="swop-eyebrow swopcase-ugc__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="swop-title swopcase-ugc__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="swopcase-ugc__strip" role="list">
        {%- for block in section.blocks -%}
          {%- assign placeholder_n = forloop.index | at_most: 3 -%}
          <li class="swopcase-ugc__item" {{ block.shopify_attributes }}>
            {%- capture card_inner -%}
              <div class="swopcase-ugc__media">
                {%- if block.settings.image != blank -%}
                  <img class="swop-media" src="{{ block.settings.image | image_url: width: 600 }}" alt="{% if block.settings.handle != blank %}Community-Look von {{ block.settings.handle | escape }}{% elsif block.settings.image.alt != blank %}{{ block.settings.image.alt | escape }}{% endif %}" width="600" height="600" loading="lazy">
                {%- else -%}
                  <img class="swop-media" src="{{ 'placeholder-ugc-' | append: placeholder_n | append: '.svg' | asset_url }}" alt="" width="600" height="600" loading="lazy">
                {%- endif -%}
                {%- if block.settings.handle != blank -%}
                  <span class="swopcase-ugc__handle">{{ block.settings.handle }}</span>
                {%- endif -%}
              </div>
            {%- endcapture -%}

            {%- if block.settings.link != blank -%}
              <a class="swopcase-ugc__card" href="{{ block.settings.link }}"{% if block.settings.handle != blank %} aria-label="Look von {{ block.settings.handle | escape }} ansehen"{% endif %}>
                {{ card_inner }}
              </a>
            {%- else -%}
              <div class="swopcase-ugc__card">
                {{ card_inner }}
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .swopcase-ugc__eyebrow,
  .swopcase-ugc__heading {
    text-align: center;
  }

  .swopcase-ugc__heading {
    margin-top: 0.4rem;
    margin-bottom: 0;
  }

  .swopcase-ugc__strip {
    list-style: none;
    margin: 1.6rem 0 0;
    padding: 0 var(--swop-gutter, 1.5rem) 0.4rem;
    display: flex;
    gap: 0.9rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    /* let the strip bleed to the screen edges on mobile for a true swipe feel */
    margin-left: calc(-1 * var(--swop-gutter, 1.5rem));
    margin-right: calc(-1 * var(--swop-gutter, 1.5rem));
  }

  .swopcase-ugc__strip::-webkit-scrollbar {
    display: none;
  }

  .swopcase-ugc__item {
    flex: 0 0 72vw;
    max-width: 280px;
    scroll-snap-align: start;
  }

  .swopcase-ugc__card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: var(--swop-radius, 14px);
    overflow: hidden;
    box-shadow: var(--swop-shadow-sm);
    background-color: var(--swop-surface, #fff);
  }

  a.swopcase-ugc__card {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  a.swopcase-ugc__card:hover,
  a.swopcase-ugc__card:focus-visible {
    transform: translateY(-2px);
    box-shadow: var(--swop-shadow);
  }

  a.swopcase-ugc__card:focus-visible {
    outline: 2px solid var(--swop-accent);
    outline-offset: 2px;
  }

  .swopcase-ugc__media {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .swopcase-ugc__media .swop-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .swopcase-ugc__handle {
    position: absolute;
    left: 0.6rem;
    bottom: 0.6rem;
    padding: 0.3rem 0.7rem;
    border-radius: var(--swop-pill, 999px);
    background-color: rgba(20, 16, 16, 0.62);
    color: #fff;
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.2;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  @media screen and (min-width: 750px) {
    .swopcase-ugc__strip {
      margin-left: 0;
      margin-right: 0;
      padding: 0;
      margin-top: 2rem;
      gap: 1.2rem;
      overflow-x: visible;
      scroll-snap-type: none;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
    }

    .swopcase-ugc__item {
      flex: initial;
      max-width: none;
    }
  }

  @media screen and (min-width: 990px) {
    .swopcase-ugc__strip {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    a.swopcase-ugc__card {
      transition: none;
    }
    a.swopcase-ugc__card:hover,
    a.swopcase-ugc__card:focus-visible {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "SwopCase: UGC-Strip",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "@swopcase"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Überschrift",
      "default": "Echte Looks aus der Community"
    },
    {
      "type": "header",
      "content": "Darstellung"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Hintergrundfarbe",
      "default": "#F1E9E9"
    },
    {
      "type": "header",
      "content": "Abstand"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand oben",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Abstand unten",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Beitrag",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild",
          "info": "Quadratisches Bild empfohlen (z. B. 600 x 600 px)."
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Handle",
          "info": "Optional. Wird auf dem Bild angezeigt, z. B. @lena.styles."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Optional. Verlinkt die Kachel, z. B. zum Originalbeitrag."
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "SwopCase: UGC-Strip",
      "blocks": [
        {
          "type": "post",
          "settings": {
            "handle": "@lena.styles"
          }
        },
        {
          "type": "post",
          "settings": {
            "handle": "@miakey"
          }
        },
        {
          "type": "post",
          "settings": {
            "handle": "@sophiie___"
          }
        }
      ]
    }
  ]
}
{% endschema %}
