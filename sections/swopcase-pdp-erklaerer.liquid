{{ 'swopcase-theme.css' | asset_url | stylesheet_tag }}
{%- style -%}
  #swopcase-pdperkl-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #swopcase-pdperkl-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
<section id="swopcase-pdperkl-{{ section.id }}" class="swop-section swopcase-pdperkl"{% if section.settings.background_color != blank %} style="background-color: {{ section.settings.background_color }};"{% endif %}>
  <div class="swop-container swop-container--narrow">
    <div class="swop-card swopcase-pdperkl__card">
      {%- if section.settings.heading != blank -%}
        <h2 class="swop-title swopcase-pdperkl__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ol class="swopcase-pdperkl__steps" role="list">
          {%- for block in section.blocks -%}
            <li class="swopcase-pdperkl__step" {{ block.shopify_attributes }}>
              <span class="swopcase-pdperkl__icon" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'case' -%}
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="6.5" y="3" width="11" height="18" rx="3"></rect>
                      <circle cx="9.5" cy="7" r="1"></circle>
                    </svg>
                  {%- when 'insert' -%}
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 3v10"></path>
                      <path d="M8.5 9.5 12 13l3.5-3.5"></path>
                      <path d="M5 15v3a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-3"></path>
                    </svg>
                  {%- when 'check' -%}
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="9"></circle>
                      <path d="m8.5 12 2.5 2.5 4.5-5"></path>
                    </svg>
                  {%- when 'phone' -%}
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="7" y="2.5" width="10" height="19" rx="2.5"></rect>
                      <path d="M10.5 18.5h3"></path>
                    </svg>
                  {%- when 'sparkle' -%}
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 3.5c.6 3.7 1.8 4.9 5.5 5.5-3.7.6-4.9 1.8-5.5 5.5-.6-3.7-1.8-4.9-5.5-5.5 3.7-.6 4.9-1.8 5.5-5.5Z"></path>
                      <path d="M18 15.5c.3 1.6.8 2.1 2.4 2.4-1.6.3-2.1.8-2.4 2.4-.3-1.6-.8-2.1-2.4-2.4 1.6-.3 2.1-.8 2.4-2.4Z"></path>
                    </svg>
                {%- endcase -%}
              </span>
              {%- if block.settings.label != blank -%}
                <span class="swopcase-pdperkl__label">{{ block.settings.label | escape }}</span>
              {%- endif -%}

              {%- unless forloop.last -%}
                <span class="swopcase-pdperkl__arrow" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m9 6 6 6-6 6"></path>
                  </svg>
                </span>
              {%- endunless -%}
            </li>
          {%- endfor -%}
        </ol>
      {%- endif -%}

      {%- if section.settings.note != blank -%}
        <p class="swop-text swopcase-pdperkl__note">{{ section.settings.note | escape }}</p>
      {%- endif -%}
    </div>
  </div>
</section>
{% stylesheet %}
  .swopcase-pdperkl__card {
    text-align: center;
  }

  .swopcase-pdperkl__heading {
    font-size: 1.0625rem;
    margin: 0 0 calc(var(--swop-space) * 0.9);
  }

  .swopcase-pdperkl__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: center;
    gap: calc(var(--swop-space) * 0.4) calc(var(--swop-space) * 0.6);
  }

  .swopcase-pdperkl__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 84px;
    position: relative;
  }

  .swopcase-pdperkl__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--swop-pill);
    background-color: var(--swop-surface-2);
    border: 1px solid var(--swop-line);
    color: var(--swop-accent);
    flex: 0 0 auto;
  }

  .swopcase-pdperkl__icon svg {
    width: 22px;
    height: 22px;
  }

  .swopcase-pdperkl__label {
    font-size: 0.8125rem;
    line-height: 1.25;
    color: var(--swop-ink);
    font-weight: 600;
  }

  .swopcase-pdperkl__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--swop-placeholder);
    position: absolute;
    top: 13px;
    left: calc(100% - 8px);
    width: calc(var(--swop-space) * 0.6 + 16px);
  }

  .swopcase-pdperkl__note {
    margin: calc(var(--swop-space) * 0.9) 0 0;
    color: var(--swop-ink-soft);
    font-size: 0.875rem;
  }

  @media screen and (max-width: 419px) {
    .swopcase-pdperkl__arrow {
      display: none;
    }
  }
{% endstylesheet %}
{% schema %}
  {
    "name": "SwopCase: PDP Mini-Erklärer",
    "tag": "section",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Überschrift",
        "default": "So funktioniert SwopCase"
      },
      {
        "type": "text",
        "id": "note",
        "label": "Hinweis (unter den Schritten)",
        "info": "Kurzer, beruhigender Zusatz.",
        "default": "In Sekunden gewechselt – beliebig oft."
      },
      {
        "type": "header",
        "content": "Darstellung"
      },
      {
        "type": "color",
        "id": "background_color",
        "label": "Hintergrundfarbe",
        "default": "#F1E9E9"
      },
      {
        "type": "header",
        "content": "Abstand"
      },
      {
        "type": "range",
        "id": "padding_top",
        "label": "Abstand oben",
        "min": 0,
        "max": 120,
        "step": 4,
        "unit": "px",
        "default": 32
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "label": "Abstand unten",
        "min": 0,
        "max": 120,
        "step": 4,
        "unit": "px",
        "default": 32
      }
    ],
    "blocks": [
      {
        "type": "step",
        "name": "Schritt",
        "settings": [
          {
            "type": "select",
            "id": "icon",
            "label": "Icon",
            "options": [
              { "value": "case", "label": "Hülle" },
              { "value": "insert", "label": "Einlegen" },
              { "value": "check", "label": "Fertig" },
              { "value": "phone", "label": "Handy" },
              { "value": "sparkle", "label": "Look" }
            ],
            "default": "case"
          },
          {
            "type": "text",
            "id": "label",
            "label": "Beschriftung",
            "default": "Hülle ab"
          }
        ]
      }
    ],
    "max_blocks": 5,
    "presets": [
      {
        "name": "SwopCase: PDP Mini-Erklärer",
        "blocks": [
          {
            "type": "step",
            "settings": {
              "icon": "case",
              "label": "Hülle ab"
            }
          },
          {
            "type": "step",
            "settings": {
              "icon": "insert",
              "label": "Swop rein"
            }
          },
          {
            "type": "step",
            "settings": {
              "icon": "check",
              "label": "Look fertig"
            }
          }
        ]
      }
    ]
  }
{% endschema %}
